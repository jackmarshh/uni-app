.container{display:flex;flex-direction:column;align-items:center;justify-content:space-between;height:100vh;background-color:#5c94fc;padding:50px 20px;box-sizing:border-box;font-family:Arial Black,Arial Bold,Gadget,sans-serif}.logo-area{display:flex;flex-direction:column;align-items:center;margin-top:60px}.game-title{font-size:40px;color:red;text-shadow:4px 4px 0 #000;letter-spacing:2px;margin-bottom:10px}.game-subtitle{font-size:60px;color:gold;text-shadow:4px 4px 0 #000,-2px -2px 0 #b8860b;letter-spacing:4px}.menu-area{width:100%;display:flex;flex-direction:column;align-items:center;gap:20px}.menu-btn{width:80%;background-color:#e75c10;color:#fff;border:4px solid #fff;box-shadow:4px 4px #000;font-size:20px;font-weight:700;padding:15px 0;border-radius:0}.menu-btn:active{transform:translate(2px,2px);box-shadow:2px 2px #000}.help-btn{background-color:#0c0}.footer{margin-bottom:20px}.copyright{color:#fff;font-size:12px;text-shadow:1px 1px 0 #000}.modal-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background-color:rgba(0,0,0,.8);display:flex;justify-content:center;align-items:center;z-index:100}.modal-content{width:80%;background-color:#5c94fc;border:4px solid #fff;padding:20px;border-radius:10px;box-shadow:0 0 20px rgba(0,0,0,.5);display:flex;flex-direction:column;align-items:center}.modal-title{font-size:24px;color:#fff;text-shadow:2px 2px 0 #000;margin-bottom:20px;font-weight:700}.instruction-list{width:100%;margin-bottom:20px}.instruction-item{display:block;color:#fff;font-size:16px;margin-bottom:10px;text-shadow:1px 1px 0 #000;text-align:left}.modal-btn{background-color:#e75c10;color:#fff;border:2px solid #fff;padding:10px 30px;font-size:16px;font-weight:700;box-shadow:2px 2px #000}
