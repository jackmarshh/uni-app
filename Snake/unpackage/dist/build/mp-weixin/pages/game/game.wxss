.content{display:flex;flex-direction:column;align-items:center;justify-content:space-evenly;background-color:#5c94fc;height:100vh;font-family:Arial Black,Arial Bold,Gadget,sans-serif}.header-mario{width:100%;display:flex;justify-content:space-around;align-items:flex-start;padding:10px 5px;background-color:transparent}.header-item{display:flex;flex-direction:column;align-items:center}.label{color:#fff;font-size:14px;font-weight:700;text-shadow:2px 2px 0 #000;margin-bottom:2px}.value{color:#fff;font-size:16px;font-weight:700;text-shadow:2px 2px 0 #000;letter-spacing:1px}.coins-value{display:flex;align-items:center;justify-content:center}.coin-mini{width:14px;height:18px;background-color:gold;border-radius:50%;border:1px solid #b8860b;margin-right:2px;box-shadow:inset 2px 2px #ffe44d;position:relative;animation:coinSpin 1s linear infinite}.coin-mini:after{content:"";position:absolute;top:20%;left:40%;width:20%;height:60%;background-color:#b8860b}.game-area{position:relative;background-color:rgba(0,0,0,.2);border:4px solid #e75c10;box-shadow:0 0 0 4px #000,5px 5px 15px rgba(0,0,0,.5);overflow:hidden;border-radius:4px}.snake-segment{position:absolute}.inner-segment{width:100%;height:100%;background-color:#0c0;border:1px solid #004d00;box-shadow:inset 2px 2px rgba(255,255,255,.3),inset -2px -2px rgba(0,0,0,.3);border-radius:2px}.snake-head .inner-segment{background-color:red;border-color:#8b0000}.food-container{position:absolute;display:flex;justify-content:center;align-items:center}.coin{width:80%;height:80%;background-color:gold;border-radius:50%;border:2px solid #b8860b;box-shadow:inset 2px 2px #ffe44d,inset -2px -2px #daa520;animation:coinSpin 1s linear infinite}.coin:after{content:"";position:absolute;top:25%;left:45%;width:10%;height:50%;background-color:#b8860b}@keyframes coinSpin{0%{transform:scaleX(1)}50%{transform:scaleX(.1)}to{transform:scaleX(1)}}.game-over-overlay,.start-overlay{position:absolute;top:0;left:0;width:100%;height:100%;background-color:rgba(0,0,0,.85);display:flex;flex-direction:column;justify-content:center;align-items:center;z-index:10}.game-title{color:red;font-size:32px;margin-bottom:30px;text-shadow:3px 3px 0 #fff,5px 5px 0 #000;letter-spacing:2px}.game-over-title{color:#fff;font-size:30px;margin-bottom:20px;text-shadow:2px 2px 0 #000}.pixel-btn{background-color:#e75c10;color:#fff;padding:15px 30px;border:2px solid #fff;border-radius:0;font-size:18px;font-weight:700;box-shadow:4px 4px #000;text-shadow:1px 1px 0 #000;margin-bottom:10px}.pixel-btn:active{transform:translate(2px,2px);box-shadow:2px 2px #000}.controls-area{display:flex;justify-content:space-between;align-items:flex-end;width:100%;padding:0 30px 40px;box-sizing:border-box}.joystick-container-nes{width:130px;height:130px;position:relative;display:flex;justify-content:center;align-items:center;background-color:rgba(255,255,255,.1);border-radius:50%}.joystick-cross{width:120px;height:120px;position:relative}.d-pad-up,.d-pad-down,.d-pad-left,.d-pad-right,.d-pad-center{position:absolute;background-color:#222;border:1px solid #000;box-shadow:inset 0 0 5px rgba(255,255,255,.2)}.d-pad-center{top:40px;left:40px;width:40px;height:40px;z-index:2;display:flex;justify-content:center;align-items:center}.d-pad-circle{width:26px;height:26px;border-radius:50%;background:radial-gradient(circle at 30% 30%,#444,#111);border:1px solid #000}.d-pad-up{top:0;left:40px;width:40px;height:45px;border-radius:6px 6px 0 0}.d-pad-down{bottom:0;left:40px;width:40px;height:45px;border-radius:0 0 6px 6px}.d-pad-left{top:40px;left:0;width:45px;height:40px;border-radius:6px 0 0 6px}.d-pad-right{top:40px;right:0;width:45px;height:40px;border-radius:0 6px 6px 0}.action-buttons-nes{display:flex;position:relative;width:120px;height:100px}.action-btn-a,.action-btn-b{position:absolute;width:55px;height:55px;border-radius:50%;background-color:red;border:3px solid #8b0000;box-shadow:3px 3px #000;display:flex;justify-content:center;align-items:center}.action-btn-a:before,.action-btn-b:before{color:rgba(139,0,0,.5);font-weight:700;font-size:20px}.action-btn-b{left:0;bottom:0}.action-btn-b:before{content:"B"}.action-btn-a{right:0;top:0}.action-btn-a:before{content:"A"}.btn-active{transform:translate(2px,2px);box-shadow:1px 1px #000;background-color:#d00000}
